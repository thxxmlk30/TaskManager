# Copiez ce fichier en .env pour le développement local (ne jamais committer .env)

# Clé secrète Django - générez-en une nouvelle pour la production
SECRET_KEY=django-insecure-changeme-en-local-uniquement

# True en local, False en production
DEBUG=True

# Domaines autorisés à servir l'application (séparés par des virgules)
ALLOWED_HOSTS=127.0.0.1,localhost

# Origines de confiance pour le CSRF en production (ex: https://monapp.up.railway.app)
CSRF_TRUSTED_ORIGINS=

# Fournie automatiquement par Railway lorsqu'un service PostgreSQL est ajouté.
# Laissez vide en local pour utiliser SQLite.
# DATABASE_URL=postgres://user:password@host:port/dbname
